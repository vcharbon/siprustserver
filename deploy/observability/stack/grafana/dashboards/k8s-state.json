{
  "uid": "k8s-state",
  "title": "Kubernetes — state & per-pod resources",
  "tags": ["kubernetes", "kube-state-metrics", "cadvisor"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "vm" },
        "query": "label_values(kube_pod_info, namespace)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Pods running",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum(kube_pod_status_phase{phase=\"Running\", namespace=~\"$namespace\"})", "refId": "A" }]
    },
    {
      "id": 2, "type": "stat", "title": "Pods pending",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum(kube_pod_status_phase{phase=\"Pending\", namespace=~\"$namespace\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }] } } }
    },
    {
      "id": 3, "type": "stat", "title": "Pods failed",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum(kube_pod_status_phase{phase=\"Failed\", namespace=~\"$namespace\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 4, "type": "stat", "title": "Container restarts (last 1h)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[1h]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } }
    },
    {
      "id": 5, "type": "timeseries", "title": "CPU usage per pod (cAdvisor)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"$namespace\", container!=\"\", container!=\"POD\"}[1m]))", "refId": "A", "legendFormat": "{{pod}}" }],
      "fieldConfig": { "defaults": { "unit": "cores" } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Memory working set per pod",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"$namespace\", container!=\"\", container!=\"POD\"})", "refId": "A", "legendFormat": "{{pod}}" }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Container restarts / 5m by pod",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[5m]))", "refId": "A", "legendFormat": "{{pod}}" }],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 8, "type": "timeseries", "title": "Container network rx / tx per pod",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum by (pod) (rate(container_network_receive_bytes_total{namespace=~\"$namespace\"}[1m]))", "refId": "A", "legendFormat": "rx {{pod}}" },
        { "expr": "sum by (pod) (rate(container_network_transmit_bytes_total{namespace=~\"$namespace\"}[1m]))", "refId": "B", "legendFormat": "tx {{pod}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 9, "type": "table", "title": "Pod state snapshot",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "kube_pod_info{namespace=~\"$namespace\"}", "refId": "A", "format": "table", "instant": true }],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "uid": true, "host_ip": true, "host_network": true, "created_by_kind": true, "created_by_name": true, "node": false, "pod_ip": false, "namespace": false, "pod": false } } }
      ]
    }
  ]
}
