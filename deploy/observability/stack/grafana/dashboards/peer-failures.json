{
  "uid": "peer-failures",
  "title": "Per-Peer SIP Failures (b2bua + front proxy)",
  "tags": [
    "sip",
    "loadgen",
    "endurance",
    "peer",
    "failover"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "annotations": {
    "list": [
      {
        "name": "Chaos window",
        "datasource": {
          "type": "prometheus",
          "uid": "vm"
        },
        "enable": true,
        "iconColor": "semi-dark-orange",
        "expr": "sip_chaos_window == 1",
        "titleFormat": "chaos: {{type}}",
        "tagKeys": "type",
        "step": "10s"
      },
      {
        "name": "UAS crash (involuntary)",
        "datasource": {
          "type": "prometheus",
          "uid": "vm"
        },
        "enable": true,
        "iconColor": "red",
        "expr": "sip_chaos_window{type=\"uas_crash\"} == 1",
        "titleFormat": "INVOLUNTARY UAS crash (test infra)",
        "step": "10s"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "name": "pod",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "vm"
        },
        "query": "label_values(b2bua_peer_failures_total, pod)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "label": "worker pod (b2bua panels)"
      },
      {
        "name": "peer",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "vm"
        },
        "query": "label_values(b2bua_peer_failures_total, peer)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "kind",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "vm"
        },
        "query": "label_values(b2bua_peer_failures_total, kind)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "b2bua (worker) \u2014 per-peer SIP failures \u00b7 b2bua_peer_failures_total{peer,scope,kind}",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "b2bua failures/s",
      "description": "Aggregate per-peer failure rate on the workers. Failure-only family (no per-peer success counter).",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum(rate(b2bua_peer_failures_total{pod=~\"$pod\",peer=~\"$peer\",kind=~\"$kind\"}[$__rate_interval]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "b2bua failures (range)",
      "description": "Total failures recorded across the selected window.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum(increase(b2bua_peer_failures_total{pod=~\"$pod\",peer=~\"$peer\",kind=~\"$kind\"}[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "failing peers",
      "description": "Distinct peers with at least one failure in range (peer=\"__external_overflow__\" = LRU-evicted external addrs folded together).",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "count(sum by (peer) (increase(b2bua_peer_failures_total{pod=~\"$pod\",peer=~\"$peer\",kind=~\"$kind\"}[$__range])) > 0)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "external-overflow folded",
      "description": "Failures attributed to evicted external peers (PEER_METRICS_EXTERNAL_CAP overflow). High value \u21d2 raise the cap to keep addresses resolved.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum(increase(b2bua_peer_failures_total{pod=~\"$pod\",peer=\"__external_overflow__\"}[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "b2bua failures/s by peer",
      "description": "Which next hop is failing. Spikes here localize a sick worker/upstream.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum by (peer) (rate(b2bua_peer_failures_total{pod=~\"$pod\",peer=~\"$peer\",kind=~\"$kind\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{peer}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": {
            "fillOpacity": 0,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "b2bua failures/s by kind",
      "description": "kind: response_timeout (Timer B/F), transaction_timeout (INVITE backstop), keepalive_timeout (in-dialog OPTIONS), send_failure (ENOBUFS/EPERM).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum by (kind) (rate(b2bua_peer_failures_total{pod=~\"$pod\",peer=~\"$peer\",kind=~\"$kind\"}[$__rate_interval]))",
          "refId": "A",
          "legendFormat": "{{kind}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": {
            "fillOpacity": 30,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "b2bua failures/s internal vs external",
      "description": "internal = cluster peers (pinned, never evicted); external = off-cluster (LRU-bounded).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
