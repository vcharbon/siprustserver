    {
      "id": 19,
      "type": "row",
      "title": "call-outcome context \u2014 global ok / nok (no per-peer success counter; pair with the per-peer tables above)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 46
