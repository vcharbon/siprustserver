      "panels": []
    },
    {
      "id": 20,
      "type": "stat",
      "title": "loadgen ok ratio",
      "description": "Fraction of loadgen calls classed ok over the window. Drops here \u21d2 scan the per-peer failure tables to find the culprit hop.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 47
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum(rate(loadgen_calls_total{class=\"ok\"}[$__range])) / clamp_min(sum(rate(loadgen_calls_total[$__range])), 0.0001)",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
