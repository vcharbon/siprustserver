    {
      "id": 9,
      "type": "table",
      "title": "b2bua peer \u00d7 scope \u00d7 kind (range totals)",
      "description": "Sorted failure leaderboard for the selected window. Start an investigation here.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 13
