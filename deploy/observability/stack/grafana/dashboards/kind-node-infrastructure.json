{
  "uid": "kind-nodes",
  "title": "Kind — Node infrastructure (CPU / mem / disk / net)",
  "tags": ["kind", "infrastructure", "node-exporter"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "node",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "vm" },
        "query": "label_values(node_uname_info, instance)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "timeseries", "title": "CPU usage % per node",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "100 * (1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\", instance=~\"$node\"}[1m])))", "refId": "A", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 2, "type": "timeseries", "title": "Memory usage % per node",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "100 * (1 - node_memory_MemAvailable_bytes{instance=~\"$node\"} / node_memory_MemTotal_bytes{instance=~\"$node\"})", "refId": "A", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 3, "type": "timeseries", "title": "Load average (1m)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "node_load1{instance=~\"$node\"}", "refId": "A", "legendFormat": "{{instance}}" }],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 4, "type": "timeseries", "title": "Memory breakdown per node (rss / cache / available)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes{instance=~\"$node\"} - node_memory_MemAvailable_bytes{instance=~\"$node\"}", "refId": "A", "legendFormat": "used {{instance}}" },
        { "expr": "node_memory_Cached_bytes{instance=~\"$node\"}", "refId": "B", "legendFormat": "cache {{instance}}" },
        { "expr": "node_memory_MemAvailable_bytes{instance=~\"$node\"}", "refId": "C", "legendFormat": "available {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Disk read / write bytes per sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum by (instance) (rate(node_disk_read_bytes_total{instance=~\"$node\"}[1m]))", "refId": "A", "legendFormat": "read {{instance}}" },
        { "expr": "sum by (instance) (rate(node_disk_written_bytes_total{instance=~\"$node\"}[1m]))", "refId": "B", "legendFormat": "write {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Disk IOPS",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum by (instance) (rate(node_disk_reads_completed_total{instance=~\"$node\"}[1m]))", "refId": "A", "legendFormat": "read iops {{instance}}" },
        { "expr": "sum by (instance) (rate(node_disk_writes_completed_total{instance=~\"$node\"}[1m]))", "refId": "B", "legendFormat": "write iops {{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "iops" } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Network receive bytes / sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum by (instance, device) (rate(node_network_receive_bytes_total{instance=~\"$node\", device!~\"lo|veth.*\"}[1m]))", "refId": "A", "legendFormat": "{{instance}} / {{device}}" }],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 8, "type": "timeseries", "title": "Network transmit bytes / sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum by (instance, device) (rate(node_network_transmit_bytes_total{instance=~\"$node\", device!~\"lo|veth.*\"}[1m]))", "refId": "A", "legendFormat": "{{instance}} / {{device}}" }],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "id": 9, "type": "timeseries", "title": "Filesystem usage %",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "100 * (1 - node_filesystem_avail_bytes{instance=~\"$node\", fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{instance=~\"$node\", fstype!~\"tmpfs|overlay|squashfs\"})", "refId": "A", "legendFormat": "{{instance}} {{mountpoint}}" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    }
  ]
}
