{
  "uid": "b2bua-worker",
  "title": "B2BUA — Worker (Rust)",
  "tags": ["siprustserver", "b2bua"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "pod",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "vm" },
        "query": "label_values(b2bua_active_calls, pod)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Active calls",
      "description": "`b2bua_active_calls` gauge = creations − removals, summed across worker pods. Authoritative live dialog count.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum(b2bua_active_calls{pod=~\"$pod\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 2, "type": "stat", "title": "Call setups / sec",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum(rate(b2bua_call_creations_total{pod=~\"$pod\"}[1m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "id": 3, "type": "stat", "title": "Dispatch drops / sec",
      "description": "Sum of per-call queue-full drops + global call-cap drops (`b2bua_dispatch_queue_drops_total` + `b2bua_dispatch_cap_drops_total`). Non-zero means the worker is shedding load.",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum(rate(b2bua_dispatch_queue_drops_total{pod=~\"$pod\"}[1m])) + sum(rate(b2bua_dispatch_cap_drops_total{pod=~\"$pod\"}[1m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "cps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 4, "type": "stat", "title": "CDRs dropped / sec",
      "description": "`b2bua_cdr_dropped_total` — CDRs lost to buffer overflow. Should be flat zero.",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum(rate(b2bua_cdr_dropped_total{pod=~\"$pod\"}[1m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "cps", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.001 }] } } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Active calls per pod",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "b2bua_active_calls{pod=~\"$pod\"}", "refId": "A", "legendFormat": "{{pod}}" }],
      "fieldConfig": { "defaults": { "unit": "none", "min": 0 } }
    },
    {
      "id": 6, "type": "timeseries", "title": "Call creations vs removals / sec",
      "description": "`b2bua_call_creations_total` (per-call dispatch queues created) vs `b2bua_call_removals_total` (removed). Steady state: the two track each other; a persistent gap is the active-call ramp.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum(rate(b2bua_call_creations_total{pod=~\"$pod\"}[1m]))", "refId": "A", "legendFormat": "creations" },
        { "expr": "sum(rate(b2bua_call_removals_total{pod=~\"$pod\"}[1m]))", "refId": "B", "legendFormat": "removals" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Dispatch backpressure / sec",
      "description": "queue_drops (per-call FIFO full) · cap_drops (global call cap) · saturation (global handler-concurrency hits).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum by (pod) (rate(b2bua_dispatch_queue_drops_total{pod=~\"$pod\"}[1m]))", "refId": "A", "legendFormat": "queue_drops {{pod}}" },
        { "expr": "sum by (pod) (rate(b2bua_dispatch_cap_drops_total{pod=~\"$pod\"}[1m]))", "refId": "B", "legendFormat": "cap_drops {{pod}}" },
        { "expr": "sum by (pod) (rate(b2bua_dispatch_saturation_total{pod=~\"$pod\"}[1m]))", "refId": "C", "legendFormat": "saturation {{pod}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "id": 8, "type": "timeseries", "title": "Handler faults / sec",
      "description": "handler_timeouts · force_purge (loop-guard purges) · fast_reject_terminating (requests rejected on a terminating call) · unroutable_dropped (no route resolved).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum(rate(b2bua_handler_timeouts_total{pod=~\"$pod\"}[1m]))", "refId": "A", "legendFormat": "handler_timeouts" },
        { "expr": "sum(rate(b2bua_force_purge_total{pod=~\"$pod\"}[1m]))", "refId": "B", "legendFormat": "force_purge" },
        { "expr": "sum(rate(b2bua_fast_reject_terminating_total{pod=~\"$pod\"}[1m]))", "refId": "C", "legendFormat": "fast_reject_terminating" },
        { "expr": "sum(rate(b2bua_unroutable_dropped_total{pod=~\"$pod\"}[1m]))", "refId": "D", "legendFormat": "unroutable_dropped" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "id": 9, "type": "timeseries", "title": "CDR written vs dropped / sec",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum(rate(b2bua_cdr_written_total{pod=~\"$pod\"}[1m]))", "refId": "A", "legendFormat": "written" },
        { "expr": "sum(rate(b2bua_cdr_dropped_total{pod=~\"$pod\"}[1m]))", "refId": "B", "legendFormat": "dropped" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "id": 10, "type": "timeseries", "title": "Cumulative call lifecycle",
      "description": "Monotonic creations / removals counters — useful to confirm the worker is making forward progress and that removals are not stalling (would manifest as a growing active-call gap).",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum(b2bua_call_creations_total{pod=~\"$pod\"})", "refId": "A", "legendFormat": "creations total" },
        { "expr": "sum(b2bua_call_removals_total{pod=~\"$pod\"})", "refId": "B", "legendFormat": "removals total" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" } }
    },
    {
      "id": 20, "type": "row", "title": "Calls / requests / responses",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 }, "collapsed": false
    },
    {
      "id": 21, "type": "timeseries", "title": "Requests / sec by method",
      "description": "`b2bua_requests_total{method}` — every inbound SIP request the worker processes, by method. Call setups are the INVITE line here; `b2bua_call_creations_total` (top row) is the authoritative per-call rate.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum by (method) (rate(b2bua_requests_total{pod=~\"$pod\"}[1m]))", "refId": "A", "legendFormat": "{{method}}" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 12, "showPoints": "never", "lineWidth": 1, "stacking": { "mode": "normal", "group": "A" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 22, "type": "timeseries", "title": "Responses / sec by code + method",
      "description": "`b2bua_responses_total{method,code}` — every inbound SIP response the worker handles, keyed by CSeq method + status code (INVITE 200, BYE 200, OPTIONS 200, INVITE 4xx/5xx, …). A rising 5xx share flags upstream trouble.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum by (method, code) (rate(b2bua_responses_total{pod=~\"$pod\"}[1m]))", "refId": "A", "legendFormat": "{{method}} {{code}}" }],
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "fillOpacity": 12, "showPoints": "never", "lineWidth": 1, "stacking": { "mode": "normal", "group": "A" } } } },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 30, "type": "row", "title": "Memory & replication (HA)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 }, "collapsed": false
    },
    {
      "id": 31, "type": "timeseries", "title": "Worker memory (working set)",
      "description": "cAdvisor `container_memory_working_set_bytes` per worker pod — the live RSS-equivalent the OOM-killer watches. A monotonic climb across the 2h run that never plateaus = a memory leak (pair it with the active-calls leak detector).",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"sip-test\", pod=~\"b2bua-worker.*\", pod=~\"$pod\", container!=\"\", container!=\"POD\"})", "refId": "A", "legendFormat": "{{pod}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0, "custom": { "fillOpacity": 8, "showPoints": "never", "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 32, "type": "timeseries", "title": "Replication activity / sec",
      "description": "Peer-to-peer HA changelog flow (`b2bua_repl_*`). `flush_propagated` on a PRIMARY = it is shipping replicas to the backup; `pull_applied` on a BACKUP = replicas arriving; `takeover_resolved`/`takeover_hydrated` = a failed-over in-dialog request found + loaded the replica. All flat-zero in steady state; they spike around a worker kill.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum(rate(b2bua_repl_flush_propagated_total{pod=~\"$pod\"}[1m]))", "refId": "A", "legendFormat": "flush_propagated (primary→backup)" },
        { "expr": "sum(rate(b2bua_repl_pull_applied_total{pod=~\"$pod\"}[1m]))", "refId": "B", "legendFormat": "pull_applied (backup←primary)" },
        { "expr": "sum(rate(b2bua_repl_takeover_resolved_total{pod=~\"$pod\"}[1m]))", "refId": "C", "legendFormat": "takeover_resolved" },
        { "expr": "sum(rate(b2bua_repl_takeover_hydrated_total{pod=~\"$pod\"}[1m]))", "refId": "D", "legendFormat": "takeover_hydrated" }
      ],
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "fillOpacity": 8, "showPoints": "never", "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 33, "type": "stat", "title": "Backup replicas held",
      "description": "`b2bua_repl_backup_held` gauge — live replicas this fleet is holding in backup partitions for its peers. > 0 means HA is armed: if a primary dies, these are the dialogs that survive on the backup.",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum(b2bua_repl_backup_held{pod=~\"$pod\"})", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }, { "color": "green", "value": 1 }] } } }
    },
    {
      "id": 34, "type": "timeseries", "title": "Replication cumulative (forward progress)",
      "description": "Monotonic `b2bua_repl_*_total` counters per pod — confirms each worker is making HA forward progress (shipping/applying replicas, resolving takeovers) over the whole run.",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 46 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum by (pod) (b2bua_repl_flush_propagated_total{pod=~\"$pod\"})", "refId": "A", "legendFormat": "flush_propagated {{pod}}" },
        { "expr": "sum by (pod) (b2bua_repl_pull_applied_total{pod=~\"$pod\"})", "refId": "B", "legendFormat": "pull_applied {{pod}}" },
        { "expr": "sum by (pod) (b2bua_repl_takeover_hydrated_total{pod=~\"$pod\"})", "refId": "C", "legendFormat": "takeover_hydrated {{pod}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "none", "custom": { "fillOpacity": 4, "showPoints": "never", "lineWidth": 1 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] }, "tooltip": { "mode": "multi" } }
    }
  ]
}
