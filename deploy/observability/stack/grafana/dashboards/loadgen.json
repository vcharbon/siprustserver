{
  "uid": "loadgen-perf",
  "title": "Loadgen \u2014 Rust functional-perf (SIPp substitute)",
  "tags": [
    "sip",
    "loadgen",
    "endurance"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "annotations": {
    "list": [
      {
        "name": "Chaos window",
        "datasource": {
          "type": "prometheus",
          "uid": "vm"
        },
        "enable": true,
        "iconColor": "semi-dark-orange",
        "expr": "sip_chaos_window == 1",
        "titleFormat": "chaos: {{type}}",
        "tagKeys": "type",
        "step": "10s"
      },
      {
        "name": "UAS crash (involuntary)",
        "datasource": {
          "type": "prometheus",
          "uid": "vm"
        },
        "enable": true,
        "iconColor": "red",
        "expr": "sip_chaos_window{type=\"uas_crash\"} == 1",
        "titleFormat": "INVOLUNTARY UAS crash (test infra)",
        "step": "10s"
      }
    ]
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Loadgen \u2014 Rust functional-perf stream (in parallel with SIPp)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "In-flight calls",
      "description": "Live concurrent calls held by the load generator.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "max(loadgen_inflight)",
          "refId": "A",
          "legendFormat": "inflight"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Offered rate (cps, 1m)",
      "description": "Calls/s the generator is starting (target ~20).",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum(rate(loadgen_started_total[1m]))",
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "cps"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "OK ratio (5m)",
      "description": "Fraction of completed calls classified ok over the last 5 min.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum(increase(loadgen_calls_total{class=\"ok\"}[5m])) / clamp_min(sum(increase(loadgen_calls_total[5m])),1)",
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Process RSS (memory canary)",
      "description": "Load generator resident memory. Watch this with full recording on \u2014 a steady climb at flat in-flight means recording-memory growth.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "max(loadgen_process_resident_memory_bytes)",
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Mux registry (leak canary)",
      "description": "Live demux entries. Should track in-flight and return toward 0; a monotonic climb is a per-call leak.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "max(loadgen_mux_registry_size)",
          "refId": "A",
          "legendFormat": "registry"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Shed (max-in-flight)",
      "description": "Calls dropped at the max-in-flight cap (offered load the generator itself shed \u2014 raise --max-in-flight if non-zero).",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum(loadgen_shed_total)",
          "refId": "A",
          "legendFormat": "shed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Completed calls/s by result class",
      "description": "Completion rate split by result class (ok / status_503 / timeout / unexpected / panic / rfc_audit_fail / \u2026).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum by (class)(rate(loadgen_calls_total[1m]))",
          "refId": "A",
          "legendFormat": "{{class}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 12,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          },
          "unit": "cps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Completed calls/s by scenario",
      "description": "Completion rate split by scenario (basic_call / reinvite / long_call / refer).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum by (scenario)(rate(loadgen_calls_total[1m]))",
          "refId": "A",
          "legendFormat": "{{scenario}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 12,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          },
          "unit": "cps"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "End-to-end latency quantiles (s)",
      "description": "Per-scenario end-to-end call latency. NOTE: basic/reinvite/long_call include the realistic ring+talk+hold dwell, so e2e is dominated by those, not the SUT.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "max by (scenario)(loadgen_e2e_seconds{quantile=\"0.5\"})",
          "refId": "A",
          "legendFormat": "{{scenario}} p50"
        },
        {
          "expr": "max by (scenario)(loadgen_e2e_seconds{quantile=\"0.9\"})",
          "refId": "B",
          "legendFormat": "{{scenario}} p90"
        },
        {
          "expr": "max by (scenario)(loadgen_e2e_seconds{quantile=\"0.99\"})",
          "refId": "C",
          "legendFormat": "{{scenario}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 0,
            "showPoints": "never",
            "lineWidth": 1
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Setup checkpoint latency p90 (s)",
      "description": "Named checkpoint latencies (time_to_200, time_to_reinvite_200, time_to_options_200, time_to_202, time_to_charlie_200) \u2014 the SUT-facing signal independent of dwell.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "max by (scenario,checkpoint)(loadgen_checkpoint_seconds{quantile=\"0.9\"})",
          "refId": "A",
          "legendFormat": "{{scenario}}/{{checkpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 0,
            "showPoints": "never",
            "lineWidth": 1
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Process RSS over time (memory)",
      "description": "Load generator RSS over the run. Cross-reference chaos windows (annotations). Full recording keeps per-call buffers; a climb decoupled from in-flight is a recording-memory issue \u2014 lower --sample-cap or --background-record-every.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "max(loadgen_process_resident_memory_bytes)",
          "refId": "A",
          "legendFormat": "rss"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 8,
            "showPoints": "never",
            "lineWidth": 1
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Mux demux & orphans",
      "description": "Demux health: registry_size tracks inflight; orphans split by reason AND CSeq method (stray BYE vs OPTIONS = the post-failover straggler breakdown for triage). unknown_token>0 would mean a relay failure.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "max(loadgen_mux_registry_size)",
          "refId": "A",
          "legendFormat": "registry_size"
        },
        {
          "expr": "max(loadgen_inflight)",
          "refId": "B",
          "legendFormat": "inflight"
        },
        {
          "expr": "sum by (reason,method)(loadgen_mux_orphan_total)",
          "refId": "C",
          "legendFormat": "orphan {{reason}}/{{method}}"
        },
        {
          "expr": "sum(loadgen_mux_inbox_drop_total)",
          "refId": "D",
          "legendFormat": "inbox_drop"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 0,
            "showPoints": "never",
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ]
}
