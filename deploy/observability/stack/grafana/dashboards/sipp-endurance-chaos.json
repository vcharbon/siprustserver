        "x": 0,
        "y": 32
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "max by (type)(sip_chaos_window)",
          "refId": "A",
          "legendFormat": "{{type}}"
