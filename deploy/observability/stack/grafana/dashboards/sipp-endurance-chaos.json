        {
          "expr": "sum(rate(sipp_failed_calls_total{role!~\"abuse|limiter\"}[1m]))",
          "refId": "B",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 8,
            "showPoints": "never",
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Failure causes (calls/s, excl. abuse+limiter)",
      "description": "Per-second failures by SIPp failure class for REAL traffic (abuse excluded \u2014 its steady ~1/s unexpected_msg is adversarial-by-design and counted apart below).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum by (cause)(rate(sipp_failed_total{role!~\"abuse|limiter\"}[1m]))",
          "refId": "A",
          "legendFormat": "{{cause}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 18,
            "showPoints": "never",
            "lineWidth": 1,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 12,
      "type": "table",
      "title": "Failure causes (cumulative) by stream",
      "description": "Cumulative count per failure class AND per SIPp stream/endpoint (role + scenario), non-zero only. This attributes each 'unexpected_msg' (and every other cause) to the exact stream that saw it.",
