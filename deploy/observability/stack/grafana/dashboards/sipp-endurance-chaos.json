        "h": 8,
        "w": 12,
        "x": 0,
        "y": 23
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum by (cause, role, scenario)(sipp_failed_total) > 0",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Retransmissions / out-of-call / dead-call (per-s)",
      "description": "Protocol-health signals.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 23
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sum(rate(sipp_retransmissions_total[1m]))",
          "refId": "A"
        },
        {
          "expr": "sum(rate(sipp_out_of_call_msgs_total[1m]))",
          "refId": "B"
        },
        {
          "expr": "sum(rate(sipp_dead_call_msgs_total[1m]))",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 8,
            "showPoints": "never",
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "last",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 14,
      "type": "row",
      "title": "Chaos",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 31
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Chaos window (active span per type)",
      "description": "`sip_chaos_window` \u2014 1 for the full real duration of each chaos event, 0 otherwise. The rectangular pulse width = the true event length (matches the orange region annotation). Replaces the old instant-marker smear.",
