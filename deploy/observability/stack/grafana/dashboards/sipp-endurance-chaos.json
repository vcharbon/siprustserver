        "h": 8,
        "w": 12,
        "x": 12,
        "y": 49
      },
      "datasource": {
        "type": "prometheus",
        "uid": "vm"
      },
      "targets": [
        {
          "expr": "sip_chaos_orphaned",
          "refId": "A",
