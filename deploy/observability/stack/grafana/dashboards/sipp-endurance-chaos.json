{
 "uid": "sipp-endurance-chaos",
 "title": "SIPp Endurance & Chaos",
 "tags": [
  "sip",
  "endurance",
  "chaos",
  "sipp"
 ],
 "timezone": "browser",
 "schemaVersion": 39,
 "refresh": "10s",
 "time": {
  "from": "now-2h",
  "to": "now"
 },
 "annotations": {
  "list": [
   {
    "name": "Chaos window",
    "datasource": {
     "type": "prometheus",
     "uid": "vm"
    },
    "enable": true,
    "iconColor": "semi-dark-orange",
    "expr": "sip_chaos_window == 1",
    "titleFormat": "chaos: {{type}}",
    "tagKeys": "type",
    "step": "10s"
   }
  ]
 },
 "templating": {
  "list": []
 },
 "panels": [
  {
   "id": 1,
   "type": "row",
   "title": "Overview",
   "collapsed": false,
   "gridPos": {
    "h": 1,
    "w": 24,
    "x": 0,
    "y": 0
   }
  },
  {
   "id": 2,
   "type": "stat",
   "title": "Concurrent calls (all streams)",
   "description": "Live established dialogs across long+short+abuse+peak.",
   "gridPos": {
    "h": 4,
    "w": 6,
    "x": 0,
    "y": 1
   },
   "datasource": {
    "type": "prometheus",
    "uid": "vm"
   },
   "targets": [
    {
     "expr": "sum(sipp_current_calls)",
     "refId": "A"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 4000
       },
       {
        "color": "red",
        "value": 8000
       }
      ]
     }
    },
    "overrides": []
   },
   "options": {
    "colorMode": "value",
    "graphMode": "area",
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "id": 3,
   "type": "stat",
   "title": "Call setup rate (created/s)",
   "description": "Aggregate INVITEs/s created by all UAC streams.",
   "gridPos": {
    "h": 4,
    "w": 6,
    "x": 6,
    "y": 1
   },
   "datasource": {
    "type": "prometheus",
    "uid": "vm"
   },
   "targets": [
    {
     "expr": "sum(rate(sipp_calls_created_total[1m]))",
     "refId": "A"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       }
      ]
     },
     "decimals": 1
    },
    "overrides": []
   },
   "options": {
    "colorMode": "value",
    "graphMode": "area",
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "id": 4,
   "type": "stat",
   "title": "Success ratio (5m, excl. abuse+limiter)",
   "description": "Resolved-call success ratio over 5m for REAL traffic (abuse excluded — the abuse stream is adversarial by design and floors at ~1 unexpected_msg/call; see the abuse-apart panel).",
   "gridPos": {
    "h": 4,
    "w": 6,
    "x": 12,
    "y": 1
   },
   "datasource": {
    "type": "prometheus",
    "uid": "vm"
   },
   "targets": [
    {
     "expr": "100*sum(rate(sipp_successful_calls_total{role!~\"abuse|limiter\"}[5m]))/clamp_min(sum(rate(sipp_successful_calls_total{role!~\"abuse|limiter\"}[5m]))+sum(rate(sipp_failed_calls_total{role!~\"abuse|limiter\"}[5m])),1)",
     "refId": "A"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "yellow",
        "value": 90
       },
       {
        "color": "green",
        "value": 99
       }
      ]
     },
     "unit": "percent",
     "decimals": 1
    },
    "overrides": []
   },
   "options": {
    "colorMode": "value",
    "graphMode": "area",
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   }
  },
  {
   "id": 5,
   "type": "stat",
   "title": "Failed calls (cumulative, excl. abuse+limiter)",
   "description": "Total failed calls across REAL streams (abuse excluded — counted apart in the abuse panel).",
   "gridPos": {
    "h": 4,
    "w": 6,
    "x": 18,
    "y": 1
   },
   "datasource": {
    "type": "prometheus",
    "uid": "vm"
   },
   "targets": [
    {
     "expr": "sum(sipp_failed_calls_total{role!~\"abuse|limiter\"})",
     "refId": "A"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "yellow",
        "value": 1
       },
       {
        "color": "red",
        "value": 100
       }
      ]
