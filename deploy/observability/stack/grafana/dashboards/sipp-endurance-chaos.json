          "expr": "sip_chaos_orphan_residual",
          "refId": "B",
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 8,
            "showPoints": "never",
            "lineWidth": 1
