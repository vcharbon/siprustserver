{
  "uid": "overload-protection",
  "title": "Overload Protection — Migrated Inputs, Decisions & Emergency",
  "tags": ["siprustserver", "overload", "emergency"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Rejection taxonomy (fleet-wide)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Rejections per second — by gate",
      "description": "Stacked rate of new-INVITE rejections, broken out by the migrated gate that dropped them. proxy_overload_elu/cps are the proxy-self EluCpsGate; all_workers_overloaded is the LB above_critical critical-filter emptying the candidate set; rate_cap_exhausted is the per-worker AIMD bucket; worker_panic_elu / worker_cps_hard_cap are the b2bua Tier-3 admission gate; udp_tier1_brake is the b2bua UDP ingress brake.",
      "gridPos": { "h": 9, "w": 18, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum(rate(sip_proxy_self_external_invites_rejected_total{reason=\"proxy_overload_elu\"}[1m]))", "refId": "A", "legendFormat": "proxy_overload_elu" },
        { "expr": "sum(rate(sip_proxy_self_external_invites_rejected_total{reason=\"proxy_overload_cps\"}[1m]))", "refId": "B", "legendFormat": "proxy_overload_cps" },
        { "expr": "sum(rate(sip_proxy_overload_rejections_total{reason=\"no_target_critical_filtered\"}[1m]))", "refId": "C", "legendFormat": "all_workers_overloaded" },
        { "expr": "sum(rate(sip_proxy_overload_rejections_total{reason=\"bucket_empty\"}[1m]))", "refId": "D", "legendFormat": "rate_cap_exhausted" },
        { "expr": "sum(rate(b2bua_overload_reject_total{reason=\"panic_elu\"}[1m]))", "refId": "E", "legendFormat": "worker_panic_elu" },
        { "expr": "sum(rate(b2bua_overload_reject_total{reason=\"bucket_empty\"}[1m]))", "refId": "F", "legendFormat": "worker_cps_hard_cap" },
        { "expr": "sum(rate(b2bua_udp_tier1_brake_drops_total[1m]))", "refId": "G", "legendFormat": "udp_tier1_brake" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "stacking": { "mode": "normal", "group": "A" }, "fillOpacity": 80 },
          "unit": "reqps"
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Admissions per second",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum(rate(sip_proxy_self_external_invites_admitted_total[1m]))", "refId": "A", "legendFormat": "proxy external admitted" },
        { "expr": "sum(rate(b2bua_overload_non_emergency_admitted_total[1m]))", "refId": "B", "legendFormat": "worker non-emergency admitted" },
        { "expr": "sum(rate(b2bua_emergency_admitted_total[1m]))", "refId": "C", "legendFormat": "worker emergency admitted" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Worker Tier-3 aggregate rejections (rate)",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum(rate(b2bua_overload_rejected_total[5m]))", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.001 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Emergency (per-gate bypass — emergency traffic skipping each gate)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Emergency admitted per second (worker Tier-3)",
      "description": "b2bua_emergency_admitted_total: emergency new-dialog INVITEs the Tier-3 gate admitted (always admitted, bypassing the bucket-empty + panic-ELU checks; NOT counted on adm).",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sum(rate(b2bua_emergency_admitted_total[1m]))", "refId": "A", "legendFormat": "emergency admitted" }],
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Per-gate emergency bypass per second",
      "description": "Emergency INVITEs that skipped each overload gate under load. proxy_self = EluCpsGate bypass; lb = LB above_critical critical-filter + AIMD bucket bypass; udp_tier1 = b2bua UDP ingress brake bypass. Non-zero under flood means emergency traffic is correctly routed while non-emergency load is shed.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum(rate(sip_proxy_self_emergency_bypassed_total[1m]))", "refId": "A", "legendFormat": "proxy_self" },
        { "expr": "sum(rate(sip_proxy_lb_emergency_bypassed_total[1m]))", "refId": "B", "legendFormat": "lb_critical_filter+aimd" },
        { "expr": "sum(rate(b2bua_udp_tier1_emergency_bypassed_total[1m]))", "refId": "C", "legendFormat": "udp_tier1_brake" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Proxy-self gate state (ELU/CPS decision inputs)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "panels": []
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "sip_proxy_self_elu_ewma (proxy ELU)",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sip_proxy_self_elu_ewma", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "sip_proxy_self_cps_bucket_level",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sip_proxy_self_cps_bucket_level", "refId": "A", "legendFormat": "level" },
        { "expr": "sip_proxy_self_cps_bucket_max", "refId": "B", "legendFormat": "max" }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "sip_proxy_self_gc_fraction",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "sip_proxy_self_gc_fraction", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1, "min": 0 } }
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Proxy-self admits & bypasses per second",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "sum(rate(sip_proxy_self_external_invites_admitted_total[1m]))", "refId": "A", "legendFormat": "external admitted" },
        { "expr": "sum(rate(sip_proxy_self_emergency_bypassed_total[1m]))", "refId": "B", "legendFormat": "emergency bypass" },
        { "expr": "sum(rate(sip_proxy_self_internal_bypassed_total[1m]))", "refId": "C", "legendFormat": "internal bypass" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "sip_proxy_worker_stale_decrease_total (rate)",
      "description": "WorkerLoadObserver sweep_stale floor events (AIMD cap halved — no fresh X-Overload within payload_stale_ms). Non-zero while ELU is healthy = a config/probe-cadence invariant break.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "rate(sip_proxy_worker_stale_decrease_total[1m])", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Worker-side overload signals (cross-check, X-Overload publish surface)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "panels": []
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "b2bua_overload_elu_ewma (published on X-Overload)",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "b2bua_overload_elu_ewma", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "b2bua_overload_token_bucket_level",
      "description": "Current CPS token-bucket level (tokens remaining; a negative emergency overdraft reads as 0).",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "b2bua_overload_token_bucket_level", "refId": "A" }],
      "fieldConfig": { "defaults": { "min": 0 } }
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "b2bua_overload_gc_fraction (structurally 0 on Rust)",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 34 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [{ "expr": "b2bua_overload_gc_fraction", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "b2bua_overload_admit_total (rate, total admits)",
      "description": "New-dialog INVITEs admitted by the Tier-3 overload gate (non-emergency adm + emergency).",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "rate(b2bua_overload_admit_total[1m])", "refId": "A", "legendFormat": "admit total" },
        { "expr": "rate(b2bua_overload_non_emergency_admitted_total[1m])", "refId": "B", "legendFormat": "non-emergency" },
        { "expr": "rate(b2bua_emergency_admitted_total[1m])", "refId": "C", "legendFormat": "emergency" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 35,
      "type": "timeseries",
      "title": "b2bua_overload_reject_total (worker-side panic + CPS hard cap)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 41 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "rate(b2bua_overload_reject_total{reason=\"panic_elu\"}[1m])", "refId": "A", "legendFormat": "panic_elu" },
        { "expr": "rate(b2bua_overload_reject_total{reason=\"bucket_empty\"}[1m])", "refId": "B", "legendFormat": "cps_bucket" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Worker UDP Tier-1 ingress brake",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "panels": []
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "b2bua_udp_tier1 brake drops / rejects / emergency-bypass (rate)",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 49 },
      "datasource": { "type": "prometheus", "uid": "vm" },
      "targets": [
        { "expr": "rate(b2bua_udp_tier1_brake_drops_total[1m])", "refId": "A", "legendFormat": "brake drops" },
        { "expr": "rate(b2bua_udp_tier1_reject_sent_total[1m])", "refId": "B", "legendFormat": "503 sent" },
        { "expr": "rate(b2bua_udp_tier1_emergency_bypassed_total[1m])", "refId": "C", "legendFormat": "emergency bypass" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } }
    }
  ]
}
