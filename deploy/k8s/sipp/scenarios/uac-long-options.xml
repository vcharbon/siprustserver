<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">
<!--
  Long-call UAC for endurance: INVITE → 200 → ACK → OPTIONS-driven hold → BYE.

  After ACK the scenario loops on in-dialog OPTIONS from the B2BUA's
  keepaliveRule (TimerRules), replying 200 OK to each. The loop is
  capped at HOLD_KEEPALIVES iterations (default 4 ≈ 20 min at the
  300 s keepalive interval) so every call eventually terminates from
  the UAC side, matching the hard-cap guarantee in
  `uac-endurance-short.xml` (`<pause milliseconds="30000"/>`). Without
  this cap, sipp's CurrentCall grows linearly for the lifetime of the
  run because the B2BUA happily keeps sending keepalives forever and
  the UAC has no other reason to send BYE — endurance-5h runs were
  reaching ~2700 concurrent long-calls instead of the intended ~480.

  Two exit paths still apply:
    - keepalive timeout (B2BUA torn down, chaos, network failure) →
      `recv timeout="350000" ontimeout="end_hold"` jumps to BYE.
    - hold cap reached → counter loop falls through to BYE.

  Earlier revisions used a flat `<pause milliseconds="1200000"/>` and
  relied on sipp's "default `pingreply` behavior" to auto-200 in-dialog
  OPTIONS during the pause. That was incorrect: sipp's `pingreply`
  only handles the legacy literal PING method, not OPTIONS. Every
  long-call therefore lost its A-leg keepalive, the B2BUA terminated
  the call ~5 min in, and the scenario's BYE 15 min later hit a dead
  dialog (481). See endurance run chaos-endurance-2h-20260511.

  Loop pattern mirrors `uas-basic.xml` (the B-leg UAS). 200 OK echoes
  `[last_From:]` / `[last_To:]` / `[last_Call-ID:]` / `[last_CSeq:]` so
  the response carries the dialog tags + CSeq from the request.

  The recv timeout is sized for the env-driven default
  `KEEPALIVE_INTERVAL_SEC=300s` (src/config/AppConfig.ts) — 350 s
  gives 50 s headroom for jitter / proxy queueing. The embedded layer
  default is 900 s; if a deployment uses the embedded layer with that
  larger interval, raise this timeout accordingly.

  RFC 3261 conformance:
    §11      In-dialog OPTIONS may be sent by either party; UAS
             responds 200 OK echoing dialog tags + CSeq.
    §12.2.1.1 In-dialog request CSeq increments within the dialog;
             sipp's 200 OK echoes the CSeq verbatim from the request.
-->
<scenario name="K8s UAC long-options — OPTIONS-driven hold; BYE on keepalive timeout">

  <send retrans="500">
    <![CDATA[
      INVITE sip:[service]@[remote_ip]:[remote_port] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch];rport
      From: sipp <sip:sipp@[local_ip]:[local_port]>;tag=[pid]SIPpTag00[call_number]
      To: sut <sip:[service]@[remote_ip]:[remote_port]>
      Call-ID: [call_id]
      CSeq: 1 INVITE
      Contact: sip:sipp@[local_ip]:[local_port]
      Max-Forwards: 70
      Subject: K8s endurance long-call (OPTIONS keepalive)
      Resource-Priority: esnet.0
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
      s=-
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0
      a=rtpmap:0 PCMU/8000
    ]]>
  </send>

  <recv response="100" optional="true"/>
  <recv response="180" optional="true"/>
  <recv response="200" rtd="true" rrs="true"/>

  <send>
    <![CDATA[
      ACK [next_url] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch];rport
      [routes]
      From: sipp <sip:sipp@[local_ip]:[local_port]>;tag=[pid]SIPpTag00[call_number]
      To: sut <sip:[service]@[remote_ip]:[remote_port]>[peer_tag_param]
      Call-ID: [call_id]
      CSeq: 1 ACK
      Contact: sip:sipp@[local_ip]:[local_port]
      Max-Forwards: 70
      Content-Length: 0
    ]]>
  </send>

  <!-- OPTIONS-driven hold: reply to each keepalive then loop back. The
       recv is MANDATORY (no optional=true) — sipp rejects an
       `optional=true recv` immediately followed by a `<send>`. With
       `ontimeout` set, mandatory recv jumps to the labeled step
       instead of aborting on timeout — so when keepalives stop
       arriving for `timeout` ms (B2BUA terminated the call, chaos
       event, network failure) we exit to the BYE phase.

       The loop is capped at 4 iterations so calls eventually
       terminate even when keepalives keep flowing — see the header
       comment. `hold_count` is incremented after each reply; `test`
       sets `hold_done` truthy once we've replied to 4 OPTIONS, and
       the `nop test=...` branches to `end_hold` instead of looping. -->
  <label id="hold_loop"/>
  <recv request="OPTIONS" crlf="true" timeout="350000" ontimeout="end_hold"/>
  <send>
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_Record-Route:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: sip:sipp@[local_ip]:[local_port]
      Content-Length: 0
    ]]>
    <action>
      <add assign_to="hold_count" value="1"/>
      <test assign_to="hold_done" variable="hold_count" compare="greater_than_equal" value="4"/>
    </action>
  </send>
  <nop test="hold_done" next="end_hold"/>
  <nop next="hold_loop"/>

  <label id="end_hold"/>
  <send retrans="500">
    <![CDATA[
      BYE [next_url] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch];rport
      [routes]
      From: sipp <sip:sipp@[local_ip]:[local_port]>;tag=[pid]SIPpTag00[call_number]
      To: sut <sip:[service]@[remote_ip]:[remote_port]>[peer_tag_param]
      Call-ID: [call_id]
      CSeq: 2 BYE
      Contact: sip:sipp@[local_ip]:[local_port]
      Max-Forwards: 70
      Content-Length: 0
    ]]>
  </send>

  <recv response="200" crlf="true"/>

  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>
  <CallLengthRepartition value="60000, 300000, 600000, 900000, 1200000"/>
</scenario>
