<?xml version="1.0" encoding="ISO-8859-1" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">
<scenario name="K8s UAS basic — answer INVITE / accept ACK / accept BYE">
  <recv request="INVITE" crlf="true"/>
  <send>
    <![CDATA[
      SIP/2.0 100 Trying
      [last_Via:]
      [last_Record-Route:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0
    ]]>
  </send>
  <send>
    <![CDATA[
      SIP/2.0 180 Ringing
      [last_Via:]
      [last_Record-Route:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0
    ]]>
  </send>
  <!-- 5s simulated ring time between 180 Ringing and 200 OK so the
       B2BUA observes realistic alert-to-answer latency on every call. -->
  <pause milliseconds="5000"/>
  <send retrans="500">
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_Record-Route:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
      s=-
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0
      a=rtpmap:0 PCMU/8000
    ]]>
  </send>
  <recv request="ACK" rtd="true" crlf="true"/>

  <!-- Tolerant of in-dialog OPTIONS sent by the B2BUA's keepalive rule
       (TimerRules.keepaliveRule). The interval is `keepaliveIntervalSec`
       — env-driven default is 300s (src/config/AppConfig.ts); embedded
       layer default is 900s. Short calls complete well before the
       keepalive timer fires so the optional recv is simply skipped;
       long endurance calls (20-min holds) see ~4 OPTIONS at 300s
       spacing and answer each with 200 OK before looping back to wait
       for either another OPTIONS or the eventual BYE. -->
  <label id="wait_terminator"/>
  <!-- In-dialog re-INVITE relayed by the B2BUA (uac-reinvite.xml exercises this).
       Answer 200 OK with an SDP answer, accept the ACK, then loop back. Optional
       so scenarios that never re-INVITE just skip it. The 200 echoes
       [last_To:] verbatim (the dialog's established To-tag is already present on
       the in-dialog re-INVITE — do NOT append another tag) and retransmits until
       the ACK arrives (2xx reliability, §13.3.1). -->
  <recv request="INVITE" optional="true" crlf="true" next="answer_reinvite"/>
  <recv request="OPTIONS" optional="true" crlf="true" next="answer_options"/>
  <recv request="BYE" crlf="true"/>
  <nop next="answer_bye"/>

  <label id="answer_reinvite"/>
  <send retrans="500">
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_Record-Route:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=user1 53655765 2353687637 IN IP[local_ip_type] [local_ip]
      s=-
      c=IN IP[media_ip_type] [media_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0
      a=rtpmap:0 PCMU/8000
    ]]>
  </send>
  <recv request="ACK" crlf="true"/>
  <nop next="wait_terminator"/>

  <label id="answer_options"/>
  <!-- 200 OK to in-dialog OPTIONS echoes [last_Record-Route:] (same as
       the BYE 200 OK below) so the reply traces back through the proxy
       with the proxy's stickiness cookie intact. -->
  <send>
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_Record-Route:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0
    ]]>
  </send>
  <nop next="wait_terminator"/>

  <label id="answer_bye"/>
  <send>
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_Record-Route:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0
    ]]>
  </send>
  <ResponseTimeRepartition value="10, 20, 30, 40, 50, 100, 150, 200"/>
  <CallLengthRepartition value="10, 50, 100, 500, 1000, 5000, 10000"/>
</scenario>
